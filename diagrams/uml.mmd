classDiagram
    %% PawPal+ class design
    %% Update this file so it matches your final implementation.

    class Owner {
        +str name
        +str email
        +str location
        +list~Pet~ pets
        +Scheduler scheduler
        +addPet(pet Pet) void
        +updateInfo(name str, email str, location str) void
        +getAllTasks() list~Task~
    }

    class Pet {
        +str name
        +float weight
        +int age
        +str species
        +str breed
        +list~str~ healthConditions
        +list~Task~ tasks
        +updateInfo(weight float, age int, breed str) void
        +addHealthCondition(condition str) void
        +addTask(task Task) void
        +getTasks() list~Task~
    }

    class Task {
        +str description
        +int durationMinutes
        +str frequency
        +int priority
        +bool completed
        +toggleComplete() void
        +markComplete() void
        +isDone() bool
        +isDueToday() bool
    }

    class Scheduler {
        +Owner owner
        +int availableMinutes
        +str location
        +getAllTasks() list~Task~
        +getTodaysTasks() list~Task~
        +generatePlan() list~Task~
        +planByPet() dict
        +markTaskComplete(task Task) void
        +explainPlan() str
    }

    Owner "1" --> "*" Pet : owns
    Owner "1" --> "1" Scheduler : uses
    Pet "1" *-- "*" Task : has
    Scheduler ..> Owner : reads tasks from
