classDiagram
    %% PawPal+ class design
    %% Update this file so it matches your final implementation.

    class Owner {
        +str name
        +str email
        +str location
        +list~Pet~ pets
        +Scheduler scheduler
        +addPet(pet Pet) void
        +updateInfo(name str, email str, location str) void
        +getAllTasks() list~Task~
    }

    class Pet {
        +str name
        +float weight
        +int age
        +str species
        +str breed
        +list~str~ healthConditions
        +list~Task~ tasks
        +updateInfo(weight float, age int, breed str) void
        +addHealthCondition(condition str) void
        +addTask(task Task) void
        +completeTask(task Task) Task
        +getTasks() list~Task~
    }

    class Task {
        +str description
        +int durationMinutes
        +str frequency
        +int priority
        +bool completed
        +str scheduledTime
        +date dueDate
        +toggleComplete() void
        +markComplete() Task
        +nextOccurrence() Task
        +isDone() bool
        +isDueToday() bool
    }

    class Scheduler {
        +Owner owner
        +int availableMinutes
        +str location
        +getAllTasks() list~Task~
        +getTodaysTasks() list~Task~
        +getPlannableTasks() list~Task~
        +filterTasks(completed bool, petName str) list~Task~
        +generatePlan() list~Task~
        +planByPet(plan list~Task~) dict
        +detectConflicts() list~str~
        +hasConflicts() bool
        +markTaskComplete(task Task) Task
        +explainPlan(plan list~Task~) str
        +sortByTime(tasks list~Task~) list~Task~
    }

    Owner "1" --> "*" Pet : owns
    Owner "1" --> "1" Scheduler : uses
    Pet "1" *-- "*" Task : has
    Scheduler ..> Owner : reads tasks from
    Task ..> Task : spawns next occurrence
